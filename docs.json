{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "linden",
  "name": "Globo Ads Design System",
  "colors": {
    "primary": "#00A4FF",
    "light": "#00A4FF",
    "dark": "#00A4FF"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "groups": [
      {
        "group": "Introdução",
        "pages": [
          "introducao/design-system",
          "introducao/design-tokens",
          "introducao/design-assets"
        ],
        "icon": "book-open"
      },
      {
        "group": "Componentes",
        "icon": "puzzle",
        "pages": [
          "componentes/button",
          "componentes/badge"
        ]
      },
      {
        "group": "Institucional",
        "icon": "building",
        "pages": [
          "institucional/sobre",
          "institucional/changelog",
          "institucional/contribuir",
          "institucional/suporte"
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/light.svg",
    "dark": "/images/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hi@mintlify.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.mintlify.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "fonts": {
    "family": "Geist"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  }
}
