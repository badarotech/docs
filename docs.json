{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "linden",
  "name": "Mintlify Starter Kit",
  "colors": {
    "primary": "#00A4FF",
    "light": "#00A4FF",
    "dark": "#00A4FF"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "groups": [
      {
        "group": "Design System",
        "pages": [
          "design-system/introducao"
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/light.svg",
    "dark": "/images/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hi@mintlify.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.mintlify.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "fonts": {
    "family": "Geist"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  }
}
